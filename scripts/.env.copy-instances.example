# ──────────────────────────────────────────────────────────────────────────────
# instances-transfer.js – environment variable template
#
# Copy this file to .env (in the project root) and fill in the values below.
# OAuth2 credentials can be created in the Copernicus Dashboard under
# User Settings → OAuth clients.
# Account ID can be found in the dashboard profile or via the
# /api/v2/configuration/profile endpoint.
# ──────────────────────────────────────────────────────────────────────────────

# ── Source account (instances will be READ from this account) ─────────────────

# OAuth2 client ID for the source Copernicus account
# ⚠️  Must belong to a root (admin) account — required to access and clone instances.
APP_SOURCE_CLIENT_ID=

# OAuth2 client secret for the source Copernicus account
# ⚠️  Must belong to a root (admin) account — required to access and clone instances.
APP_SOURCE_CLIENT_SECRET=

# ── Destination account (instances will be WRITTEN to this account) ───────────

# Domain account ID of the destination Copernicus account
# Used as the clone target and assigned to new instances
APP_DEST_ACCOUNT_ID=
